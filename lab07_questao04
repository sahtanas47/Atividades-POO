class Pessoa:
    def __init__(self, nome, altura):
        self.nome = nome
        self.altura = altura

    def __str__(self):
        return f"Nome: {self.nome} | Altura: {self.altura}"

    def __gt__(self, other):
        return self.altura > other.altura

    def __lt__(self, other):
        return self.altura < other.altura


lst = []

quantidade = int(input("Quantas pessoas deseja cadastrar? "))

for i in range(quantidade):
    nome = input("Nome: ")
    altura = float(input("Altura: "))

    pessoa = Pessoa(nome, altura)
    lst.append(pessoa)

print("\nMais alta:")
print(max(lst))

print("\nMais baixa:")
print(min(lst))

print("\nPessoas em ordem de altura:")

for pessoa in sorted(lst):
    print(pessoa)
